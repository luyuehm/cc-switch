# cc-switch environment configuration
# Copy this file to ~/.claude/cc-switch.env and fill in your values:
#   cp .env.example ~/.claude/cc-switch.env
#
# This file contains secrets — it is NOT committed to git.
#
# ⚠ NOTE: If your shell exports ANTHROPIC_BASE_URL and ANTHROPIC_AUTH_TOKEN
# (e.g. from a unified ~/.openclaw/.env via ~/.zshrc), those values take
# priority over anything in this file. You can leave this file empty.

# API key for your model proxy / CPA endpoint
ANTHROPIC_API_KEY=your-api-key-here

# Base URL for model inference (your CPA proxy or API gateway)
ANTHROPIC_BASE_URL=http://127.0.0.1:8317

# Optional: CPA model list endpoint (used by cc-sync)
# Defaults to ANTHROPIC_BASE_URL + /v1/models if not set
# CPA_MODELS_URL=http://127.0.0.1:8317/v1/models
