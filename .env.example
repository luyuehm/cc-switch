# cc-switch environment configuration
#
# Shell env vars (ANTHROPIC_BASE_URL, ANTHROPIC_AUTH_TOKEN) take priority
# over this file. For unified key management, set these in your central config
# (e.g. ~/.openclaw/.env) and have .zshrc export them:
#
#   CLAUDE_CODE_BASE_URL=http://127.0.0.1:8317
#   CPA_API_KEY=<your-cpa-key>
#
# This file is only used as a fallback when shell env vars are not set.
#
# Copy this file to ~/.claude/cc-switch.env and fill in your values:
#   cp .env.example ~/.claude/cc-switch.env

# API key for your model proxy / CPA endpoint
ANTHROPIC_API_KEY=your-api-key-here

# Base URL for model inference (your CPA proxy or API gateway)
ANTHROPIC_BASE_URL=http://127.0.0.1:8317

# Optional: CPA model list endpoint (defaults to ANTHROPIC_BASE_URL + /v1/models)
# CPA_MODELS_URL=http://127.0.0.1:8317/v1/models
